generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  content     String   @db.LongText
  categories  Json     @default("[]")
  tags        Json     @default("[]")
  coverImage  String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

model PortfolioItem {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  year       String?
  status     String?
  summary    String   @db.Text
  coverImage String?
  techStack  Json     @default("[]")
  tags       Json     @default("[]")
  links      Json     @default("{}")
  gallery    Json     @default("[]")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([sortOrder])
}

model SiteProfile {
  id        String   @id @default("default")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([filename])
}

model StudyUser {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  nickname     String?
  avatarUrl    String?
  githubId     String?  @unique
  createdAt    DateTime @default(now())
}

model StudySession {
  id           String   @id @default(cuid())
  userId       String?
  workDuration Int
  completedAt  DateTime @default(now())

  @@index([completedAt])
  @@index([userId])
}

model TodoItem {
  id        String   @id @default(cuid())
  userId    String
  label     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
